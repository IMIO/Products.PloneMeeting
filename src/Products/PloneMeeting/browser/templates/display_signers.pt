<div class="display-signers" i18n:domain="PloneMeeting">
  <label class="horizontal" i18n:translate="">Signers that will be used in the generated document:</label>
  <a class="display-signers-configure-signatories"
     tal:condition="python: view.show_manage_signatories"
     tal:attributes="href python: view.__parent__.form.cfg.absolute_url() + '?pageName=assembly_and_signatures'"
     i18n:translate="display_signers_configure_signatories">
    Not correct? Change signatories
  </a>
  <table class="vertical listing">
    <tr>
      <th i18n:translate="">Certified signatures signature number</th>
      <th i18n:translate="">Certified signatures signatory name</th>
      <th i18n:translate="">Certified signatures signatory function</th>
      <th i18n:translate="">Plone user</th>
      <th i18n:domain="plone" i18n:translate="listingheader_email_address">E-mail address</th>
    </tr>
    <tbody>
      <tr tal:repeat="signer python: view.signers">
        <td tal:content="repeat/signer/number">Signature number</td>
        <td tal:content="python: signer['name']">Signer name</td>
        <td tal:content="python: signer['function']">Signer function</td>
        <td tal:content="python: signer['userid']">Signer userid</td>
        <td tal:content="python: signer['email']">Signer email</td>
      </tr>
    </tbody>
  </table>
  <h3 tal:condition="python: view.show_esign" class="parapheo">
    <img width="24" height="24" tal:attributes="src python: view.portal_url + '/++resource++imio.esign/parapheo.svg'" />
    <span i18n:translate="esign_label">e-Signature:</span>
  </h3>
  <div metal:use-macro="context/global_statusmessage/macros/portal_message">
    Portal status message
  </div>
</div>
